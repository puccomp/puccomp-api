# EXPECTED ENVIRONMENT VARIABLES (in .env file)

NODE_ENV= # development | production

PORT=
BASE_URL=
DATABASE_URL=

# PostgreSQL credentials (used by docker-compose.prod.yml)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

FRONTEND_URLS=
INTERNAL_URL=

JWT_SECRET_KEY=

# Production only — in development, LocalStack is used automatically (http://localstack:4566)
# Override dev endpoint: AWS_ENDPOINT_URL=  AWS_PUBLIC_URL=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Production only — in development, MailHog is used automatically (mailhog:1025)
# MailHog web UI: http://localhost:8025
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE= # true | false (default false)
EMAIL_USER=
EMAIL_PASS=
TARGET_EMAIL=

DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_NAME=
DEFAULT_ADMIN_SURNAME=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_COURSE=
DEFAULT_ADMIN_ENTRY_DATE=

# Max number of assets allowed per project (default: 10)
MAX_ASSETS_PER_PROJECT=