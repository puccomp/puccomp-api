generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  level       Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  members     Member[]

  @@map("roles")
}

model Member {
  id                     Int               @id @default(autoincrement())
  email                  String            @unique
  password               String?
  name                   String?
  surname                String?
  bio                    String?
  course                 String?
  avatarUrl              String?           @map("avatar_url")
  entryDate              DateTime?         @map("entry_date") @db.Date
  exitDate               DateTime?         @map("exit_date") @db.Date
  githubUrl              String?           @map("github_url")
  instagramUrl           String?           @map("instagram_url")
  linkedinUrl            String?           @map("linkedin_url")
  isAdmin                Boolean           @map("is_admin")
  roleId                 Int?              @map("role_id")
  inviteToken            String?           @unique @map("invite_token")
  inviteTokenExpiresAt   DateTime?         @map("invite_token_expires_at")
  status                 MemberStatus      @default(PENDING)
  passwordResetToken     String?           @unique @map("password_reset_token")
  passwordResetExpiresAt DateTime?         @map("password_reset_expires_at")
  projects               Contributor[]
  decidedProposals       ProjectProposal[]
  role                   Role?             @relation(fields: [roleId], references: [id])

  @@map("members")
}

model Project {
  id           Int                 @id @default(autoincrement())
  name         String              @unique
  description  String
  createdAt    DateTime            @map("created_at") @db.Date
  updatedAt    DateTime?           @map("updated_at") @db.Date
  slug         String              @unique
  status       ProjectStatus       @default(PLANNING)
  isFeatured   Boolean             @default(false) @map("is_featured")
  priority     Int                 @default(0)
  startDate    DateTime?           @map("start_date") @db.Date
  endDate      DateTime?           @map("end_date") @db.Date
  isInternal   Boolean             @default(false) @map("is_internal")
  deadline     DateTime?           @db.Date
  contributors Contributor[]
  assets       ProjectAsset[]
  technologies ProjectTechnology[]

  @@map("projects")
}

model ProjectAsset {
  id        Int       @id @default(autoincrement())
  projectId Int       @map("project_id")
  type      AssetType @default(IMAGE)
  key       String    @unique
  caption   String?
  order     Int       @default(0)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_assets")
}

model Contributor {
  memberId  Int     @map("member_id")
  projectId Int     @map("project_id")
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([memberId, projectId])
  @@map("contributors")
}

model Technology {
  id          Int                 @id @default(autoincrement())
  name        String              @unique
  iconUrl     String?             @map("icon_url")
  type        TechnologyType      @default(OTHER)
  slug        String              @unique
  color       String?
  description String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at")
  projects    ProjectTechnology[]

  @@map("technologies")
}

model ProjectTechnology {
  projectId    Int                  @map("project_id")
  technologyId Int                  @map("technology_id")
  usageLevel   TechnologyUsageLevel @map("usage_level")
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology   Technology           @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([projectId, technologyId])
  @@map("project_technologies")
}

model CvApplication {
  cvKey       String   @id @map("cv_key")
  fullname    String
  phone       String
  linkedin    String?
  github      String?
  course      String
  period      String
  submittedAt DateTime @default(now()) @map("submitted_at")

  @@map("cv_applications")
}

model ProjectProposal {
  id                 Int            @id @default(autoincrement())
  name               String
  phone              String
  problemDescription String         @map("problem_description")
  features           String[]
  visualIdentity     String?        @map("visual_identity")
  createdAt          DateTime       @default(now()) @map("created_at")
  solutionOverview   String?        @map("solution_overview")
  status             ProposalStatus @default(PENDING)
  internalNotes      String?        @map("internal_notes")
  updatedAt          DateTime       @default(now()) @updatedAt @map("updated_at")
  referenceLinks     String[]       @map("reference_links")
  budgetRange        BudgetRange?   @map("budget_range")
  decidedById        Int?           @map("decided_by_id")
  decidedBy          Member?        @relation(fields: [decidedById], references: [id])

  @@map("project_proposals")
}

model ImageMemory {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  title       String?
  description String?
  date        String?

  @@map("image_memories")
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  DONE
  PAUSED
}

enum AssetType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum TechnologyType {
  LANGUAGE
  FRAMEWORK
  LIBRARY
  TOOL
  OTHER
}

enum TechnologyUsageLevel {
  PRIMARY
  SECONDARY
  SUPPORTIVE
  OBSOLETE
}

enum BudgetRange {
  UNDER_3K
  FROM_3K_TO_10K
  FROM_10K_TO_25K
  FROM_25K_TO_50K
  ABOVE_50K
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}
